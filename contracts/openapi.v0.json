              "type": "string"
            }
          },
          "defaultLocale": {
            "type": "string"
          }
        }
      },
      "CursorPage": {
        "required": [
          "items",
          "nextCursor",
          "hasMore"
        ],
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "nextCursor": {
            "type": [
              "null",
              "string"
            ]
          },
          "hasMore": {
            "type": "boolean"
          }
        }
      },
      "HealthStatus": {
        "required": [
          "status",
          "checkedAt"
        ],
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "checkedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "LimitReached": {
        "required": [
          "quotaKey",
          "messageKey",
          "resetsAt",
          "premiumExtends"
        ],
        "type": "object",
        "properties": {
          "quotaKey": {
            "type": "string"
          },
          "messageKey": {
            "type": "string"
          },
          "resetsAt": {
            "type": "string",
            "format": "date-time"
          },
          "premiumExtends": {
            "type": "boolean"
          }
        }
      },
      "OpaqueId": {
        "type": "string",
        "description": "A prefixed ULID (e.g. \"usr_01H...\"). No raw Guid/uuid ever crosses the API (SLICE_S1_CONTRACT.md §1b).",
        "format": "opaque-id"
      },
      "Problem": {
        "required": [
          "type",
          "title",
          "status",
          "messageKey",
          "correlationId"
        ],
        "type": "object",
        "properties": {
          "type": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "status": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "messageKey": {
            "type": "string"
          },
          "correlationId": {
            "type": "string"
          },
          "detail": {
            "type": [
              "null",
              "string"
            ]
          },
          "instance": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      }
    },
    "securitySchemes": {
      "bearer": {
        "type": "http",
        "description": "Placeholder declared at S1; S3 (identity) fills real semantics.",
        "scheme": "bearer"
      }
    }
  },
  "tags": [
