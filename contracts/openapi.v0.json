  "components": {
    "schemas": {
      "AccountSelf": {
        "required": [
          "accountId",
          "handle",
          "email",
          "ageYears",
          "locale",
          "fandomTag",
          "createdAt",
          "deletionScheduledFor"
        ],
        "type": "object",
        "properties": {
          "accountId": {
            "$ref": "#/components/schemas/OpaqueId"
          },
          "handle": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "ageYears": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "locale": {
            "type": "string"
          },
          "fandomTag": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "deletionScheduledFor": {
            "type": [
              "null",
              "string"
            ],
            "format": "date-time"
          }
        }
      },
      "AuthEmailCodeRequest": {
        "required": [
          "email"
        ],
        "type": "object",
        "properties": {
          "email": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "AuthRefreshRequest": {
        "required": [
          "refreshToken"
        ],
        "type": "object",
        "properties": {
          "refreshToken": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "AuthSessionRequest": {
        "required": [
          "email",
          "code"
        ],
        "type": "object",
        "properties": {
          "email": {
            "type": [
              "null",
              "string"
            ]
          },
          "code": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "ChallengeIssued": {
        "required": [
          "challengeId"
        ],
        "type": "object",
        "properties": {
          "challengeId": {
            "type": "string"
          }
        }
      },
      "ClientConfigResponse": {
        "required": [
          "apiVersion",
          "locales",
          "defaultLocale"
        ],
        "type": "object",
        "properties": {
          "apiVersion": {
            "type": "string"
          },
          "locales": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "defaultLocale": {
            "type": "string"
          }
        }
      },
      "CursorPage": {
        "required": [
          "items",
          "nextCursor",
          "hasMore"
        ],
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "nextCursor": {
            "type": [
              "null",
              "string"
            ]
          },
          "hasMore": {
            "type": "boolean"
          }
        }
      },
      "DeviceRegistered": {
        "required": [
          "deviceId"
        ],
        "type": "object",
        "properties": {
          "deviceId": {
            "type": "string"
          }
        }
      },
      "DeviceRegisterRequest": {
        "required": [
          "platform",
          "pushToken"
        ],
        "type": "object",
        "properties": {
          "platform": {
            "type": [
              "null",
              "string"
            ]
          },
          "pushToken": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "EmailChangeRequest": {
        "required": [
          "email"
        ],
        "type": "object",
        "properties": {
          "email": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "EmailVerificationConfirmRequest": {
        "required": [
          "challengeId",
          "code"
        ],
        "type": "object",
        "properties": {
          "challengeId": {
            "type": [
              "null",
              "string"
            ]
          },
          "code": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "EmailVerificationRequest": {
        "required": [
          "email",
          "locale"
        ],
        "type": "object",
        "properties": {
          "email": {
            "type": [
              "null",
              "string"
            ]
          },
          "locale": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "ExportRequested": {
        "required": [
          "exportId"
        ],
        "type": "object",
        "properties": {
          "exportId": {
            "type": "string"
          }
        }
      },
      "ExportStatus": {
        "required": [
          "state",
          "expiresAt"
        ],
        "type": "object",
        "properties": {
          "state": {
            "type": "string"
          },
          "expiresAt": {
            "type": [
              "null",
              "string"
            ],
            "format": "date-time"
          }
        }
      },
      "HandleAvailabilityResponse": {
        "required": [
          "available"
        ],
        "type": "object",
        "properties": {
          "available": {
            "type": "boolean"
          }
        }
      },
      "HandleChangeRequest": {
        "required": [
          "handle"
        ],
        "type": "object",
        "properties": {
          "handle": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "HealthStatus": {
        "required": [
          "status",
          "checkedAt"
        ],
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "checkedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "LimitReached": {
        "required": [
          "quotaKey",
          "messageKey",
          "resetsAt",
          "premiumExtends"
        ],
        "type": "object",
        "properties": {
          "quotaKey": {
            "type": "string"
          },
          "messageKey": {
            "type": "string"
          },
          "resetsAt": {
            "type": "string",
            "format": "date-time"
          },
          "premiumExtends": {
            "type": "boolean"
          }
        }
      },
      "OpaqueId": {
        "type": "string",
        "description": "A prefixed ULID (e.g. \"usr_01H...\"). No raw Guid/uuid ever crosses the API (SLICE_S1_CONTRACT.md §1b).",
        "format": "opaque-id"
      },
      "Problem": {
        "required": [
          "type",
          "title",
          "status",
          "messageKey",
          "correlationId"
        ],
        "type": "object",
        "properties": {
          "type": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "status": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "messageKey": {
            "type": "string"
          },
          "correlationId": {
            "type": "string"
          },
          "detail": {
            "type": [
              "null",
              "string"
            ]
          },
          "instance": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "PushConsentRow": {
        "required": [
          "category",
          "enabled"
        ],
        "type": "object",
        "properties": {
