    "/v1/me": {
      "get": {
        "tags": [
          "MeEndpoints"
        ],
        "operationId": "GetMe",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AccountSelf"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AccountSelf": {
        "required": [
          "accountId",
          "handle",
          "email",
          "ageYears",
          "locale",
          "fandomTag",
          "createdAt",
          "deletionScheduledFor"
        ],
        "type": "object",
        "properties": {
          "accountId": {
            "$ref": "#/components/schemas/OpaqueId"
          },
          "handle": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "ageYears": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "locale": {
            "type": "string"
          },
          "fandomTag": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "deletionScheduledFor": {
            "type": [
              "null",
              "string"
            ],
            "format": "date-time"
          }
        }
      },
      "AuthEmailCodeRequest": {
        "required": [
          "email"
        ],
        "type": "object",
        "properties": {
          "email": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "AuthRefreshRequest": {
        "required": [
          "refreshToken"
        ],
        "type": "object",
        "properties": {
          "refreshToken": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "AuthSessionRequest": {
        "required": [
          "email",
          "code"
        ],
        "type": "object",
        "properties": {
          "email": {
            "type": [
              "null",
              "string"
            ]
          },
          "code": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "ChallengeIssued": {
        "required": [
          "challengeId"
        ],
        "type": "object",
        "properties": {
          "challengeId": {
            "type": "string"
          }
        }
      },
      "ClientConfigResponse": {
        "required": [
          "apiVersion",
          "locales",
          "defaultLocale"
        ],
        "type": "object",
        "properties": {
          "apiVersion": {
            "type": "string"
          },
          "locales": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "defaultLocale": {
            "type": "string"
          }
        }
      },
      "CursorPage": {
        "required": [
          "items",
          "nextCursor",
          "hasMore"
        ],
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "nextCursor": {
            "type": [
              "null",
              "string"
            ]
          },
          "hasMore": {
            "type": "boolean"
          }
        }
      },
      "EmailVerificationConfirmRequest": {
        "required": [
          "challengeId",
          "code"
        ],
        "type": "object",
        "properties": {
          "challengeId": {
            "type": [
              "null",
              "string"
            ]
          },
          "code": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "EmailVerificationRequest": {
        "required": [
          "email",
          "locale"
        ],
        "type": "object",
        "properties": {
          "email": {
            "type": [
              "null",
              "string"
            ]
          },
          "locale": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "HandleAvailabilityResponse": {
        "required": [
          "available"
        ],
        "type": "object",
        "properties": {
          "available": {
            "type": "boolean"
          }
        }
      },
      "HealthStatus": {
        "required": [
          "status",
          "checkedAt"
        ],
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "checkedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "LimitReached": {
        "required": [
          "quotaKey",
          "messageKey",
          "resetsAt",
          "premiumExtends"
        ],
        "type": "object",
        "properties": {
          "quotaKey": {
            "type": "string"
          },
          "messageKey": {
            "type": "string"
          },
          "resetsAt": {
            "type": "string",
            "format": "date-time"
          },
          "premiumExtends": {
            "type": "boolean"
          }
        }
      },
      "OpaqueId": {
        "type": "string",
        "description": "A prefixed ULID (e.g. \"usr_01H...\"). No raw Guid/uuid ever crosses the API (SLICE_S1_CONTRACT.md §1b).",
        "format": "opaque-id"
      },
      "Problem": {
        "required": [
          "type",
          "title",
          "status",
          "messageKey",
          "correlationId"
        ],
        "type": "object",
        "properties": {
          "type": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "status": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "messageKey": {
            "type": "string"
          },
          "correlationId": {
            "type": "string"
          },
          "detail": {
            "type": [
              "null",
              "string"
            ]
          },
          "instance": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "SessionCreated": {
        "required": [
          "accessToken",
          "accessExpiresAt",
          "refreshToken",
          "accountId"
        ],
        "type": "object",
        "properties": {
          "accessToken": {
            "type": "string"
          },
          "accessExpiresAt": {
            "type": "string",
            "format": "date-time"
          },
          "refreshToken": {
            "type": "string"
          },
          "accountId": {
            "$ref": "#/components/schemas/OpaqueId"
          }
        }
      },
      "SignupCompleteRequest": {
        "required": [
          "verifiedToken",
          "handle",
          "birthdate",
          "fandomTag",
          "locale"
        ],
        "type": "object",
        "properties": {
          "verifiedToken": {
            "type": [
              "null",
              "string"
            ]
          },
          "handle": {
            "type": [
              "null",
              "string"
            ]
          },
          "birthdate": {
            "type": [
              "null",
              "string"
            ]
          },
          "fandomTag": {
            "type": [
              "null",
              "string"
            ]
          },
          "locale": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "VerifiedTokenIssued": {
        "required": [
          "verifiedToken"
        ],
        "type": "object",
        "properties": {
          "verifiedToken": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "bearer": {
        "type": "http",
        "description": "Placeholder declared at S1; S3 (identity) fills real semantics.",
        "scheme": "bearer"
      }
    }
  },
  "tags": [
    {
      "name": "Svac.PublicApi"
    },
    {
      "name": "SignupEndpoints"
    },
    {
      "name": "AuthEndpoints"
    },
    {
      "name": "MeEndpoints"
    }
  ]
}