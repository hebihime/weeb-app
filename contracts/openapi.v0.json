          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SignupCompleteRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SessionCreated"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
