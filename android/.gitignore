# android/.gitignore — SLICE_S7_CONTRACT.md. Generated + build output is never committed; the
# openapi-generator kotlin client is regenerated from contracts/openapi.v0.json at build time.
.gradle/
build/
*/build/
**/build/
local.properties
captures/
.cxx/
*.iml
.idea/
# openapi-generator output (regenerated by :apikit:openApiGenerate)
apikit/src/generated/
**/generated/openapi/
.DS_Store
# Roborazzi images: baselines committed from CI artifacts, never local recordings
**/src/test/snapshots/
