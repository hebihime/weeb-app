<?xml version="1.0" encoding="utf-8"?>
<!--
  android/app/src/main/AndroidManifest.xml — SLICE_S7_CONTRACT.md §9f. usesCleartextTraffic="false" is
  the release-safe default; the debug-only network_security_config override (src/debug/res/xml) is what
  permits the dev-loopback cleartext exception, never this file. No INTERNET permission is declared
  here — release makes zero network calls (§1d fail-closed by absence); src/debug/AndroidManifest.xml
  adds it only for debug builds, where the diagnostics screen needs it.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:name="app.client.WeebApplication"
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher"
        android:allowBackup="false"
        android:usesCleartextTraffic="false"
        android:networkSecurityConfig="@xml/network_security_config"
        android:theme="@style/Theme.WeebApp">

        <activity
            android:name="app.client.MainActivity"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

    </application>

</manifest>
