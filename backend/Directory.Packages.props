<Project>
  <!--
    backend/Directory.Packages.props — Central Package Management (CPM), first real consumer S1.
    One version per package, resolved identically across every project in the solution. Fixes the class
    of MSB3277 "conflicting assembly version" warnings a multi-project solution gets the instant two
    projects each pin the same transitive package (e.g. Microsoft.EntityFrameworkCore.Relational) to
    slightly different floors — cheaper to prevent centrally than to re-pin per project as it recurs.
  -->
  <PropertyGroup>
    <ManagePackageVersionsCentrally>true</ManagePackageVersionsCentrally>
  </PropertyGroup>

  <ItemGroup>
    <!-- EF Core / Npgsql -->
    <PackageVersion Include="Microsoft.EntityFrameworkCore" Version="10.0.9" />
    <PackageVersion Include="Microsoft.EntityFrameworkCore.Design" Version="10.0.9" />
    <PackageVersion Include="Microsoft.EntityFrameworkCore.Relational" Version="10.0.9" />
    <PackageVersion Include="Npgsql.EntityFrameworkCore.PostgreSQL" Version="10.0.2" />

    <!-- ASP.NET Core / OpenAPI -->
    <PackageVersion Include="Microsoft.AspNetCore.OpenApi" Version="10.0.9" />
    <!-- Pinned above Microsoft.AspNetCore.OpenApi's transitive Microsoft.OpenApi 2.0.0, which NuGet
         audit flags as a known high-severity advisory (GHSA-v5pm-xwqc-g5wc) that TreatWarningsAsErrors
         (Directory.Build.props) turns build-failing. -->
    <PackageVersion Include="Microsoft.OpenApi" Version="2.10.0" />
    <PackageVersion Include="Microsoft.AspNetCore.Mvc.Testing" Version="10.0.9" />
    <!-- Admin host (SLICE_S5_CONTRACT.md §1a, disposition 13 confirmed): QuickGrid ships out-of-band from
         the ASP.NET Core shared framework; pinned to the SAME 10.0.9 release train as every other
         Microsoft.AspNetCore.* package above. -->
    <PackageVersion Include="Microsoft.AspNetCore.Components.QuickGrid" Version="10.0.9" />

    <!-- Hosting -->
    <PackageVersion Include="Microsoft.Extensions.Hosting.Abstractions" Version="10.0.9" />
    <PackageVersion Include="Microsoft.Extensions.DependencyInjection.Abstractions" Version="10.0.9" />

    <!-- Test -->
    <PackageVersion Include="Microsoft.NET.Test.Sdk" Version="17.14.1" />
    <PackageVersion Include="xunit" Version="2.9.3" />
    <PackageVersion Include="xunit.runner.visualstudio" Version="3.1.0" />
    <PackageVersion Include="Testcontainers.PostgreSql" Version="4.4.0" />

    <!--
      AimlRouter (SLICE_S2_CONTRACT.md §1b/§8, 15A): the ONE provider SDK reference permitted anywhere
      in the backend, and it is legal ONLY inside Svac.AimlRouter (never .Contracts) — ProviderSdkArchTest
      enforces this both directions. Chosen over hand-rolled HttpClient calls to the Messages API
      (search-before-building, CLAUDE.md): 220 GitHub stars, pushed within the last 5 months, 2.47M NuGet
      downloads, ships a net10.0 target matching this solution's TFM exactly — no polyfill/netstandard
      shim tax. Rejected: the "Anthropic" package (also on NuGet, similar download count) has a less
      idiomatic/actively-maintained-for-.NET-10 surface; Anthropic.SDK's Messages API shape is what this
      module's AnthropicApiTransport is written against.
    -->
    <PackageVersion Include="Anthropic.SDK" Version="5.10.0" />

    <!--
      Identity (SLICE_S3_CONTRACT.md §1b, §8/§9: "IEmailSender ... a REAL SMTP transport over compose
      Mailpit"). MailKit chosen over the legacy, Microsoft-deprecated System.Net.Mail.SmtpClient
      (search-before-building, CLAUDE.md): 245M+ NuGet downloads, actively maintained (jstedfast),
      first-class STARTTLS/auth support prod SMTP relays require (Mailpit needs neither, but the SAME
      impl "points at any prod relay by config" per §1b — SmtpClient's IETF-flagged deprecation and its
      well-known thread-safety/async footguns make it unfit for that prod path). MimeKit is MailKit's
      own message-building dependency (same author/repo), pinned explicitly for the same
      transitive-version-drift reason every other CPM entry here exists.
    -->
    <PackageVersion Include="MailKit" Version="4.17.0" />
    <PackageVersion Include="MimeKit" Version="4.17.0" />

    <!--
      Admin host staff auth (SLICE_S5_CONTRACT.md §1b: "Prod/Staging: OIDC to Entra ID via
      Microsoft.Identity.Web (Layer-1 standard; no hand-rolled OIDC)"). Microsoft's own first-party
      library for ASP.NET Core <-> Entra ID (formerly Azure AD) integration — the only Layer-1 candidate
      for this exact seam (search-before-building, CLAUDE.md): 1,300+ GitHub stars, maintained by the
      Entra/identity platform team itself, 190M+ NuGet downloads, ships a net8.0 target that runs
      unmodified on net10.0. Hand-rolling OIDC against Entra's endpoints was REJECTED at the contract
      level (§1a: "Layer-1 standard; no hand-rolled OIDC") — this is the one legal way this host ever
      speaks to Entra.
    -->
    <PackageVersion Include="Microsoft.Identity.Web" Version="4.13.0" />
  </ItemGroup>
</Project>
