          }
        }
      }
    },
    "state.dignity.counterpartProtection.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You're not in trouble"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No estás en problemas"
          }
