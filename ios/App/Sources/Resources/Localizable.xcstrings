            "value": "你没有任何问题"
          }
        }
      }
    },
    "state.dignity.counterpartProtection.body": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Our safety team will see the messages between you and this person. That's all that happens."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Nuestro equipo de seguridad verá los mensajes entre tú y esta persona. Eso es todo lo que ocurre."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Nossa equipe de segurança vai ver as mensagens entre você e essa pessoa. Isso é tudo o que acontece."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "我们的安全团队将查看你与此人之间的消息。仅此而已。"
          }
        }
      }
    },
    "state.preFirstCon.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Save your first con for the deck"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Guarda tu primer con para el mazo"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Guarde seu primeiro evento para o baralho"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "把你的第一场展会加入卡组"
          }
