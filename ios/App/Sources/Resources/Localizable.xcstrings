    "state.connect.empty.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your deck is warming up"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu mazo se está calentando"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Seu baralho está esquentando"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你的卡组正在预热"
          }
        }
      }
    },
    "state.connect.empty.body": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "New faces show up once the hall fills in. Check back soon — nothing to fake here."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Aparecerán caras nuevas en cuanto se llene el salón. Vuelve pronto, aquí no inventamos nada."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Novos rostos aparecem quando o salão enche. Volte em breve, aqui nada é inventado."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "等大厅里的人多起来,新面孔就会出现。稍后再来看看,这里不会伪造任何东西。"
          }
        }
      }
    },
    "state.connect.empty.cta": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Refresh the deck"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Actualizar el mazo"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Atualizar o baralho"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "刷新卡组"
          }
        }
      }
    },
    "state.explore.empty.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Nothing between contests right now"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Nada entre concursos por ahora"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Nada entre eventos por agora"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "目前活动之间暂无内容"
          }
        }
      }
    },
    "state.explore.empty.body": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This is the same screen whether the list is truly empty or your filters removed everything. Nothing is hidden from you."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta es la misma pantalla tanto si la lista está realmente vacía como si tus filtros lo quitaron todo. No se te oculta nada."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta é a mesma tela, quer a lista esteja realmente vazia quer os seus filtros tenham removido tudo. Nada é escondido de você."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无论列表本身是空的,还是你的筛选条件清空了结果,这个界面都是一样的。没有任何内容对你隐藏。"
          }
        }
      }
    },
    "state.explore.empty.cta": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Clear filters"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Borrar filtros"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Limpar filtros"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "清除筛选"
          }
        }
      }
    },
    "state.crews.empty.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No crew yet"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Aún sin crew"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Ainda sem crew"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "还没有小队"
          }
        }
      }
    },
    "state.crews.empty.body": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Crews are found families that never expire. Get invited, or start one of your own."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las crews son familias elegidas que nunca caducan. Que te inviten, o forma la tuya."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "As crews são famílias escolhidas que nunca vencem. Seja convidado, ou comece a sua."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "小队是永不过期的选择家庭。等待被邀请,或者自己创建一个。"
          }
        }
      }
    },
    "crews.create.premium.cta": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Create a crew (Premium)"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Crear una crew (Premium)"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Criar uma crew (Premium)"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "创建小队(高级版)"
          }
        }
      }
    },
    "state.inbox.empty.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No matches yet"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Aún sin coincidencias"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Ainda sem correspondências"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "还没有匹配"
          }
        }
      }
    },
    "state.inbox.empty.body": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Requests and messages land here the moment they happen. Nothing to show yet — that's the honest truth."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las solicitudes y mensajes llegarán aquí en el momento en que ocurran. Todavía no hay nada que mostrar, esa es la verdad."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Pedidos e mensagens chegam aqui no momento em que acontecem. Ainda não há nada para mostrar, essa é a verdade."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请求和消息一旦发生就会出现在这里。目前还没有内容可显示,这是实话。"
          }
        }
      }
    },
    "state.inbox.requests.empty.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No requests"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Sin solicitudes"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Sem pedidos"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "没有请求"
          }
        }
      }
    },
    "state.profile.empty.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Preview your profile"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Previsualiza tu perfil"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Pré-visualize seu perfil"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "预览你的个人资料"
          }
        }
      }
    },
    "state.profile.empty.body": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This is what others will see once you finish signing up. Nothing is published yet."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto es lo que verán los demás en cuanto termines de registrarte. Aún no se ha publicado nada."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "É isso que os outros verão quando você terminar de se cadastrar. Nada foi publicado ainda."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这是你完成注册后其他人会看到的内容。目前还没有发布任何东西。"
          }
        }
      }
    },
    "state.profile.empty.cta": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Finish signing up"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Terminar el registro"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Terminar o cadastro"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "完成注册"
          }
        }
      }
    },
    "state.gate.pending.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You're in, checking finishes soon"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ya estás dentro, la verificación termina pronto"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Você já entrou, a verificação termina em breve"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你已进入,核验很快完成"
          }
        }
      }
    },
    "state.gate.pending.body": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You keep interim access while this finishes. Usually under 10 minutes."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantienes acceso provisional mientras esto termina. Normalmente menos de 10 minutos."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Você mantém acesso provisório enquanto isso termina. Normalmente menos de 10 minutos."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在此完成之前,你将保留临时访问权限。通常不到10分钟。"
          }
        }
      }
    },
    "state.presence.fallback.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Can't confirm you're here yet"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Aún no podemos confirmar que estás aquí"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Ainda não conseguimos confirmar que você está aqui"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "暂时无法确认你在现场"
          }
        }
      }
    },
    "state.presence.fallback.body": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Try the venue Wi-Fi, or scan the QR code at the front desk instead."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Prueba con el wifi del recinto, o escanea el código QR en el mostrador."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Tente o Wi-Fi do local, ou escaneie o código QR na recepção."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请尝试连接场馆Wi-Fi,或在前台扫描二维码。"
          }
        }
      }
    },
    "state.battle.pause.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Battle paused"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Batalla en pausa"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Batalha em pausa"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "对战已暂停"
          }
        }
      }
    },
    "state.battle.pause.body": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Resume within the countdown or it counts as a forfeit for both sides."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Reanuda antes de que acabe la cuenta atrás o cuenta como abandono para ambos."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Retome dentro da contagem regressiva ou conta como desistência para os dois lados."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请在倒计时内继续,否则双方都将被视为弃权。"
          }
        }
      }
    },
    "state.connectivity.offline.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No connection"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Sin conexión"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Sem conexão"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "没有网络连接"
          }
        }
      }
    },
    "state.connectivity.offline.body": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Check your connection and try again. Nothing was sent."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Comprueba tu conexión e inténtalo de nuevo. No se ha enviado nada."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Verifique sua conexão e tente novamente. Nada foi enviado."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请检查网络连接后重试。尚未发送任何内容。"
          }
        }
      }
    },
    "state.contract.mismatch.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This app needs an update"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta app necesita una actualización"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Este app precisa de uma atualização"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此应用需要更新"
          }
        }
      }
    },
    "state.contract.mismatch.body": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The server speaks a language this build doesn't have yet. Nothing broke on your end."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El servidor habla un idioma que esta versión aún no tiene. No se rompió nada de tu lado."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O servidor fala um idioma que esta versão ainda não tem. Nada quebrou do seu lado."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "服务器使用了此版本尚不支持的语言。这不是你这边的问题。"
          }
        }
      }
    },
    "state.dignity.ageLockout.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Here's what still works"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto es lo que sigue funcionando"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Aqui está o que ainda funciona"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "以下功能仍可使用"
          }
        }
      }
    },
    "state.dignity.ageLockout.body": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "We couldn't confirm your age for this feature yet. Everything else in the app stays open."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Aún no pudimos confirmar tu edad para esta función. Todo lo demás en la app sigue disponible."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Ainda não conseguimos confirmar sua idade para este recurso. Todo o resto no app continua disponível."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
