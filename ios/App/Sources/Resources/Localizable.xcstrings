          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Este correo ya está registrado. Si no fuiste tú, no es necesario hacer nada."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Este e-mail já está registrado. Se não foi você, nenhuma ação é necessária."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此邮箱已被注册。如果不是你本人操作,无需任何操作。"
          }
        }
      }
    },
    "email.sessions_revoked.subject": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Security notice: your Weeb sessions were revoked"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Aviso de seguridad: se revocaron tus sesiones de Weeb"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Aviso de segurança: suas sessões do Weeb foram revogadas"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "安全提示:你的 Weeb 会话已被撤销"
          }
        }
      }
    },
    "email.sessions_revoked.body": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "We detected reuse of a previously-issued sign-in token and revoked every active session on your account for your protection."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Detectamos la reutilización de un token de inicio de sesión ya emitido y revocamos todas las sesiones activas de tu cuenta para tu protección."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Detectamos a reutilização de um token de login já emitido e revogamos todas as sessões ativas da sua conta para sua proteção."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "我们检测到一个此前签发的登录令牌被重复使用,为保护你的账户安全,已撤销账户上的所有活跃会话。"
          }
        }
      }
    },
