          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se cambió el correo de tu cuenta. Si no fuiste tú, revoca tus sesiones de inmediato."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O e-mail da sua conta foi alterado. Se não foi você, revogue suas sessões imediatamente."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你的账户邮箱已更改。如果不是你本人操作,请立即撤销你的会话。"
          }
        }
      }
    },
