        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Something went wrong on our end. Try again in a moment."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Algo salió mal de nuestro lado. Inténtalo de nuevo en un momento."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Algo deu errado do nosso lado. Tente novamente em um instante."
          }
        },
