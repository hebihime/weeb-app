    "state.preFirstCon.body": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The deck comes alive once you're checked in somewhere. Until then, this is your online-mode home."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El mazo cobra vida en cuanto hagas check-in en algún lugar. Hasta entonces, este es tu hogar en modo online."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O baralho ganha vida quando você faz check-in em algum lugar. Até então, este é o seu lar no modo online."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "一旦你在某处签到,卡组就会变得活跃。在那之前,这里是你的在线模式主页。"
          }
        }
      }
    },
