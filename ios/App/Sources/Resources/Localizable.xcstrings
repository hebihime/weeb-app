    "signup.refusal.under18.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This app is for ages 18 and up"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta app es para mayores de 18 años"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Este app é para maiores de 18 anos"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此应用仅供18岁及以上用户使用"
          }
        }
      }
    },
    "signup.refusal.under18.body": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "We couldn't create an account with the birthdate you entered. This isn't personal — it's the age floor for everyone."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No pudimos crear una cuenta con la fecha de nacimiento indicada. No es nada personal, es el límite de edad para todos."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Não conseguimos criar uma conta com a data de nascimento informada. Não é pessoal, é o limite de idade para todos."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "我们无法用你输入的出生日期创建账户。这不是针对个人,而是所有人都适用的年龄门槛。"
          }
        }
      }
    },
    "signup.refusal.under13.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This app isn't available to you yet"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta app aún no está disponible para ti"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Este app ainda não está disponível para você"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此应用目前尚未对你开放"
          }
        }
      }
    },
    "signup.refusal.under13.body": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "US law (COPPA) sets a hard floor at age 13 for services like this one. We didn't create an account, and we didn't keep what you entered."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La ley de EE. UU. (COPPA) fija un límite estricto de 13 años para servicios como este. No creamos una cuenta y no conservamos lo que introdujiste."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "A lei dos EUA (COPPA) fixa um limite rígido de 13 anos para serviços como este. Não criamos uma conta e não guardamos o que você digitou."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "美国法律(COPPA)为此类服务设定了13岁的硬性年龄门槛。我们没有创建账户,也没有保留你输入的信息。"
          }
        }
      }
    },
